---
const projects = [
  {
    title: "Enterprise Sales Intelligence Platform",
    desc: "End-to-end BI solution for a 500-person SaaS company. Designed a medallion-architecture data warehouse on BigQuery, modelled 40+ dbt models, and delivered a 12-page executive Power BI report reducing reporting time from 3 days to 15 minutes.",
    tags: ["dbt", "BigQuery", "Power BI", "Python", "Airflow"],
    highlight: true,
    metrics: ["15 min ↓ from 3 days", "40+ dbt models", "$2M ARR visible"],
    link: "#",
    github: "#",
  },
  {
    title: "Real-time Retail Inventory Dashboard",
    desc: "Streaming pipeline (Pub/Sub → BigQuery) feeding a Looker dashboard for 200+ store managers. Enabled live stock-out detection and cut manual stock checks by 80%.",
    tags: ["BigQuery", "Looker", "Pub/Sub", "SQL", "LookML"],
    highlight: false,
    metrics: ["200+ stores", "< 2 min latency", "80% less manual work"],
    link: "#",
    github: "#",
  },
  {
    title: "Finance Reconciliation Automation",
    desc: "Python + Airflow pipeline to reconcile transactional data across 5 source systems. Replaced a 4-hour manual process with a nightly automated job with full audit trail.",
    tags: ["Python", "Airflow", "Snowflake", "SQL"],
    highlight: false,
    metrics: ["5 source systems", "4 hrs → 20 mins", "Full audit log"],
    link: "#",
    github: "#",
  },
  {
    title: "Customer 360 Semantic Layer",
    desc: "Built a unified semantic model in dbt Metrics + Looker that became the single source of truth for customer KPIs across Sales, Marketing, and CS teams.",
    tags: ["dbt Metrics", "Looker", "BigQuery", "LookML"],
    highlight: false,
    metrics: ["3 teams unified", "12 KPIs defined", "0 discrepancies"],
    link: "#",
    github: "#",
  },
];
---

<section class="section" id="projects">
  <div class="container">
    <p class="section-label">Featured Projects</p>
    <h2 class="section-title">Things I've built and shipped</h2>

    <div class="projects-grid">
      {projects.map((p, i) => (
        <article class={`project-card card ${p.highlight ? "featured" : ""}`}>
          {p.highlight && <span class="featured-badge">Featured</span>}

          <div class="project-header">
            <svg class="project-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" width="28" height="28">
              <rect x="3" y="3" width="18" height="18" rx="2"/>
              <path d="M3 9h18M9 21V9"/>
            </svg>
            <div class="project-links">
              <a href={p.github} class="icon-link" title="Source code" target="_blank" rel="noopener">
                <svg viewBox="0 0 24 24" width="18" height="18" fill="currentColor">
                  <path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0024 12c0-6.63-5.37-12-12-12z"/>
                </svg>
              </a>
              <a href={p.link} class="icon-link" title="Live demo" target="_blank" rel="noopener">
                <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2">
                  <path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/>
                  <polyline points="15 3 21 3 21 9"/>
                  <line x1="10" y1="14" x2="21" y2="3"/>
                </svg>
              </a>
            </div>
          </div>

          <h3 class="project-title">{p.title}</h3>
          <p class="project-desc">{p.desc}</p>

          <!-- Metrics -->
          <div class="project-metrics">
            {p.metrics.map(m => (
              <span class="metric">{m}</span>
            ))}
          </div>

          <!-- Tags -->
          <div class="project-tags">
            {p.tags.map(t => <span class="tag">{t}</span>)}
          </div>
        </article>
      ))}
    </div>

    <p class="projects-footer">
      <a href="https://github.com/YOUR_GITHUB_USERNAME" target="_blank" rel="noopener" class="btn">
        View all on GitHub →
      </a>
    </p>
  </div>
</section>

<style>
  .projects-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(460px, 1fr));
    gap: 1.5rem;
    margin-bottom: 2.5rem;
  }

  .project-card {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    position: relative;
  }
  .project-card.featured {
    border-color: rgba(245, 166, 35, 0.3);
    background: linear-gradient(135deg, var(--bg-card) 0%, rgba(245,166,35,0.04) 100%);
  }

  .featured-badge {
    position: absolute;
    top: -1px; right: 1.5rem;
    background: var(--accent);
    color: #000;
    font-family: var(--font-mono);
    font-size: 0.65rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    padding: 0.25rem 0.75rem;
    border-radius: 0 0 6px 6px;
  }

  .project-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
  }
  .project-icon { color: var(--text-dim); }

  .project-links {
    display: flex;
    gap: 0.5rem;
  }
  .icon-link {
    color: var(--text-dim);
    transition: color 0.2s;
    display: flex;
    align-items: center;
  }
  .icon-link:hover { color: var(--accent); }

  .project-title {
    font-family: var(--font-body);
    font-size: 1.1rem;
    font-weight: 500;
    color: var(--text);
    line-height: 1.4;
  }

  .project-desc {
    font-size: 0.9rem;
    color: var(--text-muted);
    line-height: 1.75;
    flex: 1;
  }

  .project-metrics {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }
  .metric {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    padding: 0.2rem 0.6rem;
    border-radius: 4px;
    background: var(--teal-glow);
    color: var(--teal);
    border: 1px solid rgba(0,201,167,0.15);
  }

  .project-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
    padding-top: 0.5rem;
    border-top: 1px solid var(--border-soft);
  }

  .projects-footer {
    text-align: center;
  }

  @media (max-width: 600px) {
    .projects-grid { grid-template-columns: 1fr; }
  }
</style>
