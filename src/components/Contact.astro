---
---

<section class="section" id="contact">
  <div class="container contact-inner">
    <div class="contact-text">
      <p class="section-label">Get in Touch</p>
      <h2 class="contact-heading">
        Let's build something<br /><em>data-driven</em> together.
      </h2>
      <p class="contact-desc">
        Whether you have a complex data problem to solve, a BI role to fill,
        or just want to chat about data modelling — my inbox is always open.
        I'll do my best to get back to you within 24 hours.
      </p>

      <div class="contact-links">
        <a href="mailto:your@email.com" class="contact-link">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8">
            <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/>
            <polyline points="22,6 12,13 2,6"/>
          </svg>
          your@email.com
        </a>
        <a href="https://linkedin.com/in/yourhandle" class="contact-link" target="_blank" rel="noopener">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor">
            <path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"/>
            <rect x="2" y="9" width="4" height="12"/>
            <circle cx="4" cy="4" r="2"/>
          </svg>
          linkedin.com/in/yourhandle
        </a>
        <a href="https://github.com/YOUR_GITHUB_USERNAME" class="contact-link" target="_blank" rel="noopener">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor">
            <path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0024 12c0-6.63-5.37-12-12-12z"/>
          </svg>
          github.com/YOUR_GITHUB_USERNAME
        </a>
      </div>
    </div>

    <!-- Simple contact card -->
    <div class="contact-card card">
      <h3 class="contact-card-title">Send a message</h3>
      <p class="contact-card-note">
        This is a static site — clicking "Send" will open your default mail
        client. You can also reach me directly via the links on the left.
      </p>

      <div class="form-group">
        <label class="form-label" for="name">Your name</label>
        <input
          id="name"
          type="text"
          class="form-input"
          placeholder="Ada Lovelace"
          autocomplete="name"
        />
      </div>
      <div class="form-group">
        <label class="form-label" for="email">Your email</label>
        <input
          id="email"
          type="email"
          class="form-input"
          placeholder="ada@example.com"
          autocomplete="email"
        />
      </div>
      <div class="form-group">
        <label class="form-label" for="message">Message</label>
        <textarea
          id="message"
          class="form-input form-textarea"
          placeholder="I have a data problem I'd love to chat about…"
          rows="4"
        ></textarea>
      </div>
      <button id="sendBtn" class="btn btn-filled" style="width:100%; justify-content:center;">
        Send via Email →
      </button>
    </div>
  </div>
</section>

<script>
  const sendBtn = document.getElementById("sendBtn");
  sendBtn?.addEventListener("click", () => {
    const name    = (document.getElementById("name")    as HTMLInputElement)?.value  || "";
    const email   = (document.getElementById("email")   as HTMLInputElement)?.value  || "";
    const message = (document.getElementById("message") as HTMLTextAreaElement)?.value || "";
    const subject = encodeURIComponent(`Portfolio Contact from ${name}`);
    const body    = encodeURIComponent(`From: ${name} <${email}>\n\n${message}`);
    window.location.href = `mailto:your@email.com?subject=${subject}&body=${body}`;
  });
</script>

<style>
  .contact-inner {
    display: grid;
    grid-template-columns: 1fr 460px;
    gap: 5rem;
    align-items: start;
  }

  .contact-heading {
    font-family: var(--font-display);
    font-size: clamp(2rem, 4vw, 3rem);
    color: var(--text);
    line-height: 1.2;
    margin-bottom: 1.5rem;
  }
  .contact-heading em {
    color: var(--accent);
    font-style: italic;
  }

  .contact-desc {
    color: var(--text-muted);
    font-size: 1rem;
    line-height: 1.8;
    margin-bottom: 2rem;
    max-width: 480px;
  }

  .contact-links {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .contact-link {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    font-family: var(--font-mono);
    font-size: 0.82rem;
    color: var(--text-muted);
    text-decoration: none;
    transition: color 0.2s;
  }
  .contact-link:hover { color: var(--accent); }
  .contact-link svg { color: var(--text-dim); flex-shrink: 0; }

  /* ── Form ── */
  .contact-card-title {
    font-family: var(--font-body);
    font-weight: 500;
    font-size: 1rem;
    color: var(--text);
    margin-bottom: 0.5rem;
  }

  .contact-card-note {
    font-size: 0.78rem;
    color: var(--text-dim);
    margin-bottom: 1.75rem;
    line-height: 1.6;
    padding-bottom: 1.25rem;
    border-bottom: 1px solid var(--border-soft);
  }

  .form-group {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
    margin-bottom: 1.1rem;
  }
  .form-label {
    font-family: var(--font-mono);
    font-size: 0.68rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--text-dim);
  }
  .form-input {
    background: var(--bg-elevated);
    border: 1px solid var(--border-soft);
    border-radius: 6px;
    color: var(--text);
    font-family: var(--font-body);
    font-size: 0.9rem;
    padding: 0.7rem 1rem;
    outline: none;
    transition: border-color 0.2s;
    resize: none;
  }
  .form-input:focus { border-color: var(--accent); }
  .form-input::placeholder { color: var(--text-dim); }
  .form-textarea { min-height: 110px; }

  @media (max-width: 900px) {
    .contact-inner {
      grid-template-columns: 1fr;
      gap: 3rem;
    }
  }
</style>
