---
---

<section class="section" id="about">
  <div class="container about-grid">
    <!-- Text side -->
    <div class="about-text">
      <p class="section-label">About Me</p>
      <h2 class="section-title">
        Data is a language.<br />I help organisations speak it fluently.
      </h2>

      <p class="about-para">
        I'm a Business Intelligence Engineer with a passion for building the
        full data stack — from ingestion pipelines and data modelling to
        semantic layers and executive dashboards. I believe that the best
        analytics work is invisible: it puts the right number in front of
        the right person at exactly the right moment.
      </p>
      <p class="about-para">
        My background spans finance, retail, and SaaS industries. I'm
        comfortable in the terminal, in SQL, in a whiteboard session with
        stakeholders, and in presenting findings to a C-suite audience. I
        care deeply about data quality, documentation, and building systems
        that teams can trust and maintain long after I've moved on.
      </p>
      <p class="about-para">
        When I'm not wrangling data, I enjoy <strong>photography</strong>,
        building mechanical keyboards, and hiking trails around
        <strong>Perth, WA</strong>.
      </p>

      <div class="about-tools">
        <span class="about-tools-label">Primary tools:</span>
        {["dbt", "BigQuery", "Power BI", "Python", "Airflow", "Looker"].map(t => (
          <span class="tag">{t}</span>
        ))}
      </div>
    </div>

    <!-- Card side -->
    <div class="about-card-col">
      <div class="about-photo-card">
        <!-- Replace with your actual photo by adding it to /public/photo.jpg -->
        <div class="photo-placeholder">
          <svg width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.2">
            <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/>
            <circle cx="12" cy="7" r="4"/>
          </svg>
          <span>Add your photo to<br /><code>/public/photo.jpg</code></span>
        </div>
        <div class="photo-accent-line"></div>
      </div>

      <div class="about-mini-cards">
        <div class="mini-card">
          <span class="mini-icon">📍</span>
          <div>
            <p class="mini-title">Location</p>
            <p class="mini-val">Perth, Western Australia</p>
          </div>
        </div>
        <div class="mini-card">
          <span class="mini-icon">🎓</span>
          <div>
            <p class="mini-title">Education</p>
            <p class="mini-val">B.Sc. Computer Science / Statistics</p>
          </div>
        </div>
        <div class="mini-card">
          <span class="mini-icon">🏆</span>
          <div>
            <p class="mini-title">Certifications</p>
            <p class="mini-val">dbt Analytics Engineer · Google Cloud BI</p>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .about-grid {
    display: grid;
    grid-template-columns: 1fr 400px;
    gap: 5rem;
    align-items: start;
  }

  .about-para {
    color: var(--text-muted);
    margin-bottom: 1.25rem;
    font-size: 1.025rem;
    line-height: 1.85;
  }
  .about-para strong { color: var(--text); font-weight: 500; }

  .about-tools {
    margin-top: 2rem;
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.5rem;
  }
  .about-tools-label {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    color: var(--text-dim);
    letter-spacing: 0.08em;
    margin-right: 0.25rem;
  }

  /* ── Photo card ── */
  .about-card-col {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    position: sticky;
    top: 6rem;
  }

  .about-photo-card {
    position: relative;
    background: var(--bg-card);
    border: 1px solid var(--border-soft);
    border-radius: 16px;
    overflow: hidden;
    aspect-ratio: 4/5;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .photo-placeholder {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1rem;
    color: var(--text-dim);
    text-align: center;
    font-size: 0.85rem;
    line-height: 1.5;
  }
  .photo-placeholder code {
    color: var(--accent);
    font-size: 0.8rem;
  }

  .photo-accent-line {
    position: absolute;
    bottom: 0; left: 0; right: 0;
    height: 3px;
    background: linear-gradient(90deg, var(--accent), var(--teal));
  }

  /* ── Mini cards ── */
  .about-mini-cards {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .mini-card {
    background: var(--bg-card);
    border: 1px solid var(--border-soft);
    border-radius: 10px;
    padding: 1rem 1.25rem;
    display: flex;
    align-items: center;
    gap: 1rem;
    transition: border-color 0.2s;
  }
  .mini-card:hover { border-color: var(--border); }

  .mini-icon {
    font-size: 1.2rem;
    flex-shrink: 0;
    width: 2rem;
    text-align: center;
  }
  .mini-title {
    font-family: var(--font-mono);
    font-size: 0.65rem;
    color: var(--text-dim);
    letter-spacing: 0.1em;
    text-transform: uppercase;
    margin-bottom: 0.2rem;
  }
  .mini-val {
    font-size: 0.85rem;
    color: var(--text-muted);
  }

  @media (max-width: 960px) {
    .about-grid {
      grid-template-columns: 1fr;
      gap: 3rem;
    }
    .about-card-col { position: static; }
    .about-photo-card { aspect-ratio: 3/2; max-height: 300px; }
  }
</style>
